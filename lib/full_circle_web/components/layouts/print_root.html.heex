<!DOCTYPE html>
<html lang="en">
  <head>
    <title>
      {"Print"}
    </title>
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <style>
      body { width: 100%; height: 100%; margin: 0; padding: 0; background-color: #FAFAFA; font-family: system-ui, Arial, Helvetica, sans-serif;}
      * { box-sizing: border-box; -moz-box-sizing: border-box; }
      .page { padding: 0mm; margin: 5mm auto; border: 1px #D3D3D3 solid; border-radius: 5px; background: white; box-shadow: 0 0 5px rgba(0, 0, 0, 0.1); }
      @media print { .page { border: initial; border-radius: initial; width: initial; min-height: initial; box-shadow: initial; background: initial; } }
      a { background-color: #EEEEEE; padding: 7px; text-decoration: auto; font-weight: bold; border-radius: 5px; border: 1px solid black; cursor: pointer; color: black; }
      #button { margin-left: 46.5%; margin-top: 25px; }
      .is-capitalized { text-transform: capitalize !important; }
      .is-lowercase { text-transform: lowercase !important; }
      .is-uppercase { text-transform: uppercase !important; }
      .is-italic { font-style: italic !important; }
      .is-underlined { text-decoration: underline !important; }
      .has-text-weight-light { font-weight: 300 !important; }
      .has-text-weight-normal { font-weight: 400 !important; }
      .has-text-weight-medium { font-weight: 500 !important; }
      .has-text-weight-semibold { font-weight: 600 !important; }
      .has-text-weight-bold { font-weight: 700 !important; }
      .is-size-1 { font-size: 3rem !important;}
      .is-size-2 { font-size: 2.5rem !important;}
      .is-size-3 { font-size: 2rem !important;}
      .is-size-4 { font-size: 1.5rem !important;}
      .is-size-5 { font-size: 1.25rem !important;}
      .is-size-6 { font-size: 1rem !important;}
      .is-size-7 { font-size: 0.75rem !important;}
      .font-mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
      .border { border: solid 1px black; }
      #email-status { text-align: center; margin-top: 8px; font-weight: bold; min-height: 1.3em; }
      #email-status.ok { color: #15803d; }
      #email-status.err { color: #b91c1c; }
      #email-btn.is-busy { opacity: 0.55; pointer-events: none; animation: fcpulse 1.1s ease-in-out infinite; }
      @keyframes fcpulse { 50% { opacity: 0.2; } }
    </style>
  </head>
  <body>
    <div id="button">
      <a href="#" onclick="printElement('print-me')">{gettext("Print")}</a>
      <a
        :if={assigns[:email_doc] && !assigns[:shared_view?]}
        id="email-btn"
        href="#"
        data-company-id={@email_doc.company_id}
        data-doc-type={@email_doc.type}
        data-doc-id={@email_doc.id}
        onclick="emailDocument(this); return false;"
      >
        {gettext("Email")}
      </a>
      <a href="#" onclick="closeTab()">{gettext("Close")}</a>
    </div>
    <div id="email-status"></div>
    {@inner_content}
    <script>
      document.addEventListener("keydown", evt => {
        if (evt.key === 'Escape') { close(); }
      });

      function closeTab() {
        close();
      }

      function printElement(elm) {
        var browser = (function (agent) {
          switch (true) {
            case agent.indexOf("edge") > -1: return "MS Edge (EdgeHtml)";
            case agent.indexOf("edg") > -1: return "MS Edge Chromium";
            case agent.indexOf("opr") > -1 && !!window.opr: return "opera";
            case agent.indexOf("chrome") > -1 && !!window.chrome: return "chrome";
            case agent.indexOf("trident") > -1: return "Internet Explorer";
            case agent.indexOf("firefox") > -1: return "firefox";
            case agent.indexOf("safari") > -1: return "safari";
            default: return "other";
          }
        })(window.navigator.userAgent.toLowerCase());
        switch(browser) {
          case "firefox": document.getElementById("print-me").classList.add("firefox-page"); break;
          default: document.getElementById("print-me").classList.add("chrome-page");
        }
        const printContents = document.getElementById(elm).innerHTML;
        const originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        document.body.innerHTML = originalContents;
      }

      function setEmailStatus(kind, msg) {
        const status = document.getElementById("email-status");
        if (!status) { return; }
        status.className = kind;
        status.textContent = msg;
      }

      async function emailDocument(el) {
        if (el.dataset.busy === "1") { return; }

        const meta = document.querySelector("meta[name='csrf-token']");
        const csrf = meta ? meta.content : "";
        const companyId = el.dataset.companyId;
        const docType = el.dataset.docType;
        const docId = el.dataset.docId;

        let recipient = "";
        try {
          const q = `company_id=${encodeURIComponent(companyId)}` +
                    `&doc_type=${encodeURIComponent(docType)}` +
                    `&doc_id=${encodeURIComponent(docId)}`;
          const res = await fetch(`/email_document/new?${q}`, {
            headers: { "x-csrf-token": csrf }
          });
          const data = await res.json();
          recipient = data.recipient || "";
        } catch (e) { /* fall back to an empty prompt */ }

        const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        let entered = window.prompt("Email this document to:", recipient);
        while (entered !== null && !emailRe.test(entered.trim())) {
          entered = window.prompt(
            "That is not a valid email address. Please re-enter:", entered.trim());
        }
        if (entered === null) { return; }
        const addr = entered.trim();

        const label = el.textContent;
        el.dataset.busy = "1";
        el.classList.add("is-busy");
        el.textContent = "Sending…";
        setEmailStatus("", "");

        try {
          const res = await fetch("/email_document", {
            method: "POST",
            headers: { "content-type": "application/json", "x-csrf-token": csrf },
            body: JSON.stringify({
              company_id: companyId, doc_type: docType, doc_id: docId, email: addr
            })
          });
          const data = await res.json();
          if (data.ok) {
            setEmailStatus("ok", "✓ Document link emailed to " + addr);
            setTimeout(function () { setEmailStatus("", ""); }, 8000);
          } else {
            setEmailStatus("err", "✗ " + (data.error || "Could not send the email."));
          }
        } catch (e) {
          setEmailStatus("err", "✗ Could not send the email — check your connection and try again.");
        } finally {
          el.dataset.busy = "";
          el.classList.remove("is-busy");
          el.textContent = label;
        }
      }
    </script>
  </body>
</html>
