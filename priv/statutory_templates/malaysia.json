{
  "bundle_version": 1,
  "calcs": [
    {
      "code": "epf_relief_cap",
      "effective_from": "1957-01-01",
      "name": "EPF Relief Cap",
      "script": "result = 4000"
    },
    {
      "code": "pcb_individual_deduction",
      "effective_from": "1957-01-01",
      "name": "PCB Individual Deduction",
      "script": "result = 9000"
    },
    {
      "code": "pcb_spouse_deduction",
      "effective_from": "1957-01-01",
      "name": "PCB Spouse Deduction",
      "script": "result = 4000"
    },
    {
      "code": "pcb_child_deduction",
      "effective_from": "1957-01-01",
      "name": "PCB Child Deduction",
      "script": "result = 2000"
    },
    {
      "code": "epf_employer",
      "effective_from": "1957-01-01",
      "name": "EPF Employer",
      "script": "total = wages + bonus\nrate = if(total <= 10, 0,\n       if(not malaysian, 0.02,\n       if(age >= 60, 0.04,\n       if(total <= 5000, 0.13, 0.12))))\nresult = ceil(total * rate)"
    },
    {
      "code": "epf_employee",
      "effective_from": "1957-01-01",
      "name": "EPF Employee",
      "script": "total = wages + bonus\nrate = if(total <= 10, 0,\n       if(not malaysian, 0.02,\n       if(age >= 60, 0, 0.11)))\nresult = ceil(total * rate)"
    },
    {
      "code": "socso_employer",
      "effective_from": "1957-01-01",
      "name": "SOCSO Employer",
      "script": "result = if(age >= 60, lookup(\"socso\", wages, \"employer_only\"), lookup(\"socso\", wages, \"employer\"))"
    },
    {
      "code": "socso_employee",
      "effective_from": "1957-01-01",
      "name": "SOCSO Employee",
      "script": "result = if(age >= 60, 0, lookup(\"socso\", wages, \"employee\"))"
    },
    {
      "code": "socso_employer_only",
      "effective_from": "1957-01-01",
      "name": "SOCSO Employer Only",
      "script": "result = lookup(\"socso\", wages, \"employer_only\")"
    },
    {
      "code": "socso_24hour",
      "effective_from": "2026-06-01",
      "name": "SOCSO 24 Hour (SKBBK)",
      "script": "result = lookup(\"socso\", wages, \"employee_24hour\")"
    },
    {
      "code": "eis_employer",
      "effective_from": "1957-01-01",
      "name": "EIS Employer",
      "script": "result = if(age < 60 and malaysian, lookup(\"eis\", wages, \"employer\"), 0)"
    },
    {
      "code": "eis_employee",
      "effective_from": "1957-01-01",
      "name": "EIS Employee",
      "script": "result = if(age < 60 and malaysian, lookup(\"eis\", wages, \"employee\"), 0)"
    },
    {
      "code": "eis_employer_only",
      "effective_from": "1957-01-01",
      "name": "EIS Employer Only",
      "script": "result = lookup(\"eis\", wages, \"employer\")"
    },
    {
      "code": "pcb_employee",
      "effective_from": "1957-01-01",
      "name": "PCB Employee",
      "script": "cap = calc(\"epf_relief_cap\")\ny   = ytd_sum(type: \"Addition\") + ytd_sum(name: \"Employee Current Year Income\")\nk   = min(ytd_sum(name: [\"EPF By Employee\", \"EPF By Employee Current Year\"]), cap)\ny1  = wages\nk1  = if(k >= cap, 0, min(calc(\"epf_employee\"), cap - k))\ny2  = y1\nn   = 12 - pay_month\nk2  = if(k + k1 == 0, 0, if(k + k1 * n >= cap, 0, cap - (k + k1 * n)))\nyt  = bonus\nkt  = if(k + k1 + k2 == 0, 0,\n      if(k + k1 + k2 >= cap, 0, min(calc(\"epf_employee\"), cap - (k + k1 + k2))))\nd   = calc(\"pcb_individual_deduction\")\ns   = if(marital_status == \"Married\" and not partner_working,\n         calc(\"pcb_spouse_deduction\"), 0)\nq   = calc(\"pcb_child_deduction\")\np   = y - k + (y1 - k1) + (y2 - k2) * n + (yt - kt) - (d + s + q * children)\nm   = lookup(\"pcb_normal\", p, \"m\")\nr   = lookup(\"pcb_normal\", p, \"r\")\nb   = if(marital_status == \"Married\" and not partner_working,\n         lookup(\"pcb_normal\", p, \"b2\"),\n         lookup(\"pcb_normal\", p, \"b13\"))\nx   = ytd_sum(name: [\"Employee PCB\", \"PCB Current Year\"])\nz   = ytd_sum(name: [\"Employee Zakat\", \"Zakat Current Year\"])\npcb = ((p - m) * r + b - (z + x)) / (n + 1)\nresult = if(pcb > 0, round(pcb, 1), 0)"
    }
  ],
