= link_to 'New Order', new_sales_order_path, class: 'btn btn-success'
= simple_form_for :arrangement, url: new_arrangement_path, method: :get do |f|
  #sales_orders
    %table.table-bordered.table
      %thead
        %tr
          %td.span2
          %th.span3 Date
          %th.span3 Deliver
          %th.span7 Customer
          %th.span7 Product
          %th.span3 Package
          %th.span4 Quantity
          %th.span7 Supplier
          %th.span10 Transport
      %tbody 
        - for t in @sales_orders
          %tr
            %td.span2= check_box_tag "", t.id, nil, id: dom_id(t), class: 'sales_order_row'
            %td.span3= t.doc_date
            %td.span3= t.deliver_at
            %td.span7= link_to t.customer_name.first(20), edit_sales_order_path(t.id)
            %td.span7= label_tag dom_id(t), t.product_name
            %td.span3= label_tag dom_id(t), (t.package_qty.to_i == 0 ? '' : t.package_qty.to_i.to_s) + ' ' + t.packaging_name
            %td.span4= label_tag dom_id(t), number_with_precision(t.quantity, precision: 2, delimiter: ',') + " " + t.unit
            %td.span7= link_to 'Select Supplier', '#'
            %td.span10= link_to 'Arrange Transport', '#'
        - if @sales_orders.length == 0
          %tr
            %td{colspan: 9}
              %h2 No Record found!
  = f.button :submit, 'Multi-Orders Single Transport', class: 'btn btn-danger'