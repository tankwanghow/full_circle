= render_flash
= simple_nested_form_for @purchase_order, html: { class: 'span42 form-inline well' } do |f|
  %legend
    Purchases Order
  = render 'purchase_orders/fields', f: f
  .form-actions
    = f.button :submit, 'Save', class: 'btn btn-primary'
    = link_to 'Cancel', PurchaseOrder.last ? edit_purchase_order_path(PurchaseOrder.last) : root_path, class: 'btn btn-warning'
