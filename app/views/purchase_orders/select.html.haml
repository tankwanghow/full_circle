%h4
  %span
  = @sod.sales_order.customer_name1 + ' ordered ' + @sod.product_name1 + ' ' + (@sod.package_qty.to_i == 0 ? '' : @sod.package_qty.to_i.to_s) + ' (' + @sod.packaging_name + ') ' + number_with_precision(@sod.balance, precision: 2, delimiter: ',') + " " + @sod.unit

= simple_form_for :arrangement, url: arrangements_path, method: :post do |f|
  #purchase_orders
    %table.table-bordered.table
      %thead
        %tr
          %th.span3 Date
          %th.span3 Available
          %th.span7 Supplier
          %th.span7 Product
          %th.span3 Package
          %th.span4 Quantity
          %th.span4 Load Quantity
      %tbody 
        - for t in @purchase_orders
          %tr
            = hidden_field_tag("arrangement[sales_order_detail_id]", @sod.id)
            = hidden_field_tag("arrangement[purchase_order_detail_id]", t.purchase_order_detail_id)
            %td.span3= t.doc_date
            %td.span3= t.available_at
            %td.span7= link_to t.supplier_name.first(20), edit_purchase_order_path(t.id)
            %td.span7= label_tag dom_id(t), t.product_name
            %td.span3= label_tag dom_id(t), (t.package_qty.to_i == 0 ? '' : t.package_qty.to_i.to_s) + ' ' + t.packaging_name
            %td.span4= label_tag dom_id(t), number_with_precision(t.balance, precision: 2, delimiter: ',') + " " + t.unit
            %td.span3= f.input_field(:load_quantity, class: 'span35 numeric', value: @sod.quantity) + t.unit
        - if @purchase_orders.length == 0
          %tr
            %td{colspan: 9}
              %h2 No Record found!

  = f.button :submit, 'Send Selected PO', class: 'btn btn-danger'